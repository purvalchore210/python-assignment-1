import numpy as np

def get_matrix_from_user(rows, cols, name):
    """Prompts the user to enter matrix elements and returns a NumPy array."""
    print(f"\nEnter elements for the {rows}x{cols} matrix '{name}':")
    elements = []
    for i in range(rows):
        while True:
            try:
                row_input = input(f"  Enter elements for row {i+1} (space or comma-separated): ")
                # Split by space or comma, convert to float, and check count
                row_elements = [float(e) for e in row_input.replace(',', ' ').split()]
                if len(row_elements) == cols:
                    elements.append(row_elements)
                    break
                else:
                    print(f"Error: Please enter exactly {cols} elements for the row.")
            except ValueError:
                print("Error: Invalid input. Please enter numerical values.")
    return np.array(elements)

def multiply_matrices():
    # Define the dimensions for the first matrix (5x3)
    rows1, cols1 = 5, 3
    # The number of rows for the second matrix must be 3
    rows2 = cols1
    
    # Get user input for the second matrix's number of columns
    while True:
        try:
            cols2 = int(input("Enter the number of columns for the second matrix (e.g., 2, 4, 5): "))
            if cols2 > 0:
                break
            else:
                print("Error: Number of columns must be a positive integer.")
        except ValueError:
            print("Error: Invalid input. Please enter an integer.")

    # Get matrices from the user
    matrix1 = get_matrix_from_user(rows1, cols1, "Matrix 1 (5x3)")
    matrix2 = get_matrix_from_user(rows2, cols2, f"Matrix 2 (3x{cols2})")

    # Perform matrix multiplication using np.dot or @
    product_matrix = np.dot(matrix1, matrix2) #

    # Print the product matrix
    print("\n--- Input Matrices ---")
    print("Matrix 1:\n", matrix1)
    print("\nMatrix 2:\n", matrix2)
    print("\n--- Product Matrix ---")
    print("The product matrix has a shape of", product_matrix.shape)
    print(product_matrix)

if __name__ == "__main__":
    multiply_matrices()
